# Kopieer naar .env op de Mac Studio en vul echte secrets daar in.
# .env en .env.local staan in .gitignore.

# For_You app
# Mac Studio show-machine gebruikt 3310.
# Lokale MacBook/werkmap gebruikt meestal 3010.
# Start niet onbedoeld een extra server op 3000.
PORT=3310
ADMIN_PASSWORD=vervang-dit-lokaal

# Dropbox catalogus-sync
# Laat leeg voor automatische Dropbox-detectie.
# FORYOU_DROPBOX_CATALOG_DIR=/Users/jij/Dropbox/For You/Database
# FORYOU_DROPBOX_CATALOG_ENABLED=1

# UniFi Network Agent (read-only)
UNIFI_AGENT_ENABLED=1
UNIFI_API_BASE_URL=https://192.168.1.1/proxy/network/integration/v1
UNIFI_API_KEY=plak-hier-je-lokale-unifi-api-key
UNIFI_API_INSECURE_TLS=1
UNIFI_API_TIMEOUT_MS=5000
